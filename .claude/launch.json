{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$PATH && exec node node_modules/.bin/next dev --webpack"],
      "port": 3000
    },
    {
      "name": "next-prod",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && exec node node_modules/.bin/next start"],
      "port": 3000
    }
  ]
}
